{
  "name": "May6thNodeActivity",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "overrideCommand": true,
  "remoteUser": "node",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "postCreateCommand": "npm install && node -v && npm -v",
  "forwardPorts": [3000]
}
